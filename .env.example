# Local development (docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/chosei

# Supabase (production) example:
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# Rate limiting (Upstash Redis). 未設定ならレート制限は無効(ローカル/CI)。
# 本番では作成・回答系 Action の IP ベース制限のため必ず設定する。
# UPSTASH_REDIS_REST_URL=https://[your-db].upstash.io
# UPSTASH_REDIS_REST_TOKEN=[your-token]

# 自動削除 cron(Vercel Cron)。/api/cron/cleanup の認証に使う。
# 未設定だとエンドポイントは 500 を返し、誤って削除しないよう安全側に倒す。
# 本番では必ず設定する(Vercel Cron が Authorization: Bearer で自動付与する)。
# CRON_SECRET=[a-long-random-string]

# Realtime 自動更新(集計ページ)。両方設定すると Supabase Realtime を購読し、
# 未設定なら約5秒間隔のポーリングにフォールバックする(ローカル/CI はポーリング経路)。
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
